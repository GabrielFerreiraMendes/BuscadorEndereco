unit endereco.model;

interface

uses
  System.JSON, System.SysUtils, System.StrUtils, System.Variants,
  REST.Types, REST.Client, REST.Json, endereco.dto;

type
  TEnderecoModel = class(TInterfacedObject)
    class function ConsultarEndereco(Cep: String): TEndereco;
  end;

const
  URL_CEP: String = 'https://viacep.com.br/ws/{cep}/{type}';
  CT_TP_JSON: String = 'application/json';

implementation

{ TEndereco }

class function TEnderecoModel.ConsultarEndereco(Cep: String): TEndereco;
var
  RESTRequest: TRESTRequest;
  RESTClient: TRESTClient;
  RESTResponse: TRESTResponse;
  Endereco: TEndereco;
begin
  if SameText(Trim(Cep), EmptyStr) then
    raise Exception.Create('Cep inv·lido ou em branco!');

  Endereco := TEndereco.Create;
  RESTClient := TRESTClient.Create(URL_CEP);
  RESTResponse := TRESTResponse.Create(nil);
  RESTResponse.ContentType := CT_TP_JSON;
  RESTRequest := TRESTRequest.Create(nil);

  try
    RESTRequest.Client := RESTClient;
    RESTRequest.Response := RESTResponse;
    RESTRequest.Method := rmGet;
    RESTRequest.Params.AddItem('cep', Cep, pkURLSEGMENT, [], ctNone);
    RESTRequest.Params.AddItem('type', 'json', pkURLSEGMENT, [], ctNone);
    RESTRequest.Execute;

    if RESTResponse.StatusCode = 200 then
      Endereco := TJson.JsonToObject<TEndereco>(TJSONObject(RESTResponse.JSONValue));

    Result := Endereco;
  finally
    FreeAndNil(RESTClient);
    FreeAndNil(RESTResponse);
    FreeAndNil(RESTRequest);
  end;
end;

end.
